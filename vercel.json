{
  "version": 2,
  "builds": [
    { "src": "api/chat.js", "use": "@vercel/node" },
    { "src": "api/admin.js", "use": "@vercel/node" },
    { "src": "api/admin-panel.js", "use": "@vercel/node" },
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "api/admin-tools.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/chat/completions", "dest": "/api/chat.js" },
    { "src": "/v1/chat/completions", "dest": "/api/chat.js" },
    { "src": "/models", "dest": "/api/chat.js" },
    { "src": "/v1/models", "dest": "/api/chat.js" },
    { "src": "/v1/images/generations", "dest": "/api/chat.js" },
    { "src": "/images/generations", "dest": "/api/chat.js" },
    { "src": "/api/admin-panel", "dest": "/api/admin-panel.js" },
    { "src": "/api/admin", "dest": "/api/admin.js" },
    { "src": "/api/admin-auth", "dest": "/api/admin-tools.js" },
    { "src": "/api/admin-save", "dest": "/api/admin-tools.js" },
    { "src": "/api/admin-logout", "dest": "/api/admin-tools.js" },
    { "src": "/api/upload", "dest": "/api/admin-tools.js" },
    { "src": "/api/models-check", "dest": "/api/admin-tools.js" },
    { "src": "/api/docs-ia", "dest": "/api/admin-tools.js" },
    { "src": "/api/health(.*)", "dest": "/api/admin-tools.js" },
    { "src": "/api/competencia(.*)", "dest": "/api/admin-tools.js" },
    { "src": "/api/prompts(.*)", "dest": "/api/admin-tools.js" },
    { "src": "/api/rotator(.*)", "dest": "/api/admin-tools.js" },
    { "src": "/api/playground(.*)", "dest": "/api/admin-tools.js" },
    { "src": "/api/visitors(.*)", "dest": "/api/admin-tools.js" },
    { "src": "/api/logs(.*)", "dest": "/api/admin-tools.js" },
    { "src": "/api/config(.*)", "dest": "/api/admin-tools.js" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
