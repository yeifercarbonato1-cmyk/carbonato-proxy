{
  "version": 2,
  "builds": [
    { "src": "api/chat.js", "use": "@vercel/node" },
    { "src": "api/admin.js", "use": "@vercel/node" },
    { "src": "api/admin-panel.js", "use": "@vercel/node" },
    { "src": "api/admin-auth.js", "use": "@vercel/node" },
    { "src": "api/admin-save.js", "use": "@vercel/node" },
    { "src": "api/admin-logout.js", "use": "@vercel/node" },
    { "src": "api/usage-save.js", "use": "@vercel/node" },
    { "src": "api/upload.js", "use": "@vercel/node" },
    { "src": "api/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/chat/completions", "dest": "/api/chat.js" },
    { "src": "/v1/chat/completions", "dest": "/api/chat.js" },
    { "src": "/models", "dest": "/api/chat.js" },
    { "src": "/v1/models", "dest": "/api/chat.js" },
    { "src": "/v1/images/generations", "dest": "/api/chat.js" },
    { "src": "/api/upload", "dest": "/api/upload.js" },
    { "src": "/api/admin-panel", "dest": "/api/admin-panel.js" },
    { "src": "/api/admin-auth", "dest": "/api/admin-auth.js" },
    { "src": "/api/admin-save", "dest": "/api/admin-save.js" },
    { "src": "/api/usage-save", "dest": "/api/usage-save.js" },
    { "src": "/api/admin-logout", "dest": "/api/admin-logout.js" },
    { "src": "/api/admin", "dest": "/api/admin.js" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
