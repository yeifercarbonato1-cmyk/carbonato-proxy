{
  "version": 2,
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": ".",
  "routes": [
    { "src": "/api/admin-panel", "dest": "/api/admin-panel.js" },
    { "src": "/api/admin-auth", "dest": "/api/admin-auth.js" },
    { "src": "/api/admin-save", "dest": "/api/admin-save.js" },
    { "src": "/api/usage-save", "dest": "/api/usage-save.js" },
    { "src": "/api/admin-logout", "dest": "/api/admin-logout.js" },
    { "src": "/api/admin", "dest": "/api/admin.js" },
    { "src": "/", "dest": "/api/index.js" },
    { "src": "/chat/completions", "dest": "/api/chat.js" },
    { "src": "/models", "dest": "/api/chat.js" }
  ],
  "functions": {
    "api/*.js": {
      "runtime": "nodejs22.x",
      "maxDuration": 60
    }
  }
}