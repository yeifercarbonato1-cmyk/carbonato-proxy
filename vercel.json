{
  "version": 2,
  "builds": [
    { "src": "api/chat.js", "use": "@vercel/node" },
    { "src": "api/admin.js", "use": "@vercel/node" },
    { "src": "api/admin-panel.js", "use": "@vercel/node" },
    { "src": "api/admin-auth.js", "use": "@vercel/node" },
    { "src": "api/admin-save.js", "use": "@vercel/node" },
    { "src": "api/admin-logout.js", "use": "@vercel/node" },
    { "src": "api/usage-save.js", "use": "@vercel/node" },
    { "src": "api/upload.js", "use": "@vercel/node" },
    { "src": "api/models-check.js", "use": "@vercel/node" },
    { "src": "api/docs-ia.js", "use": "@vercel/node" },
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "api/health.js", "use": "@vercel/node" },
    { "src": "api/competencia.js", "use": "@vercel/node" },
    { "src": "api/prompts.js", "use": "@vercel/node" },
    { "src": "api/rotator.js", "use": "@vercel/node" },
    { "src": "api/playground.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/chat/completions", "dest": "/api/chat.js" },
    { "src": "/v1/chat/completions", "dest": "/api/chat.js" },
    { "src": "/models", "dest": "/api/chat.js" },
    { "src": "/v1/models", "dest": "/api/chat.js" },
    { "src": "/v1/images/generations", "dest": "/api/chat.js" },
    { "src": "/images/generations", "dest": "/api/chat.js" },
    { "src": "/api/upload", "dest": "/api/upload.js" },
    { "src": "/api/models-check", "dest": "/api/models-check.js" },
    { "src": "/api/docs-ia", "dest": "/api/docs-ia.js" },
    { "src": "/api/admin-panel", "dest": "/api/admin-panel.js" },
    { "src": "/api/admin-auth", "dest": "/api/admin-auth.js" },
    { "src": "/api/admin-save", "dest": "/api/admin-save.js" },
    { "src": "/api/usage-save", "dest": "/api/usage-save.js" },
    { "src": "/api/admin-logout", "dest": "/api/admin-logout.js" },
    { "src": "/api/admin", "dest": "/api/admin.js" },
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/api/health/check", "dest": "/api/health.js" },
    { "src": "/api/health/page", "dest": "/api/health.js" },
    { "src": "/api/competencia", "dest": "/api/competencia.js" },
    { "src": "/api/competencia/page", "dest": "/api/competencia.js" },
    { "src": "/api/prompts", "dest": "/api/prompts.js" },
    { "src": "/api/prompts/page", "dest": "/api/prompts.js" },
    { "src": "/api/rotator/rank", "dest": "/api/rotator.js" },
    { "src": "/api/rotator/page", "dest": "/api/rotator.js" },
    { "src": "/api/playground", "dest": "/api/playground.js" },
    { "src": "/api/playground/chat", "dest": "/api/playground.js" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
