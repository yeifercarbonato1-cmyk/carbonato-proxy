# Carbonato Proxy env vars

# Auth pública de API
# Una llave:
CARBONATO_API_KEY=pon_una_llave_larga_aqui
# O varias separadas por coma:
# CARBONATO_API_KEYS=key1,key2,key3

# Admin
ADMIN_USER=admin
ADMIN_PASS=cambia_esto
SESSION_SECRET=pon_un_secreto_largo_random
ADMIN_AUTH_MAX_FAILS=8

# Persistencia opcional en GitHub
GITHUB_TOKEN=tu_token_github_aqui

# Upload opcional
IMGBB_API_KEY=tu_api_key_imgbb_aqui

# Proveedores
MODELVERSE_KEY=tu_modelverse_key
NVIDIA_NIM_KEY=tu_nvidia_nim_key

# Modelos privados: no poner valores reales en Git
MODELO13_URL=http://host:puerto/v1/chat/completions
MODELO13_MODEL=Qwen3.6
MODELO13_KEY=

MODELO14_URL=http://host:puerto/v1/chat/completions
MODELO14_MODEL=gpt-5.5
MODELO14_KEY=
MODELO14_SYSTEM_PROMPT=

MODELO15_URL=https://api.modelverse.cn/v1/chat/completions
MODELO15_MODEL=claude-sonnet-4-6
MODELO15_KEY=$MODELVERSE_KEY

MODELO16_URL=https://api.modelverse.cn/v1/chat/completions
MODELO16_MODEL=gpt-5.5
MODELO16_KEY=$MODELVERSE_KEY

MODELO17_URL=https://opencode.ai/zen/v1/chat/completions
MODELO17_MODEL=deepseek-v4-flash-free
MODELO17_KEY=
MODELO17_SYSTEM_PROMPT=

MODELO18_URL=https://integrate.api.nvidia.com/v1/chat/completions
MODELO18_MODEL=z-ai/glm-5.1
MODELO18_KEY=$NVIDIA_NIM_KEY
MODELO18_SYSTEM_PROMPT=

MODELO19_URL=http://host:puerto/v1/chat/completions
MODELO19_MODEL=modelo_privado
MODELO19_KEY=
MODELO19_SYSTEM_PROMPT=

MODELO20_URL=https://integrate.api.nvidia.com/v1/chat/completions
MODELO20_MODEL=minimaxai/minimax-m2.7
MODELO20_KEY=$NVIDIA_NIM_KEY
MODELO20_SYSTEM_PROMPT=

MODELO21_URL=https://api.kilo.ai/api/gateway/chat/completions
MODELO21_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
MODELO21_KEY=
