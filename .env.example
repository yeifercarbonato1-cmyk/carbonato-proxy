# Variables de entorno para Carbonato Proxy

# Token de GitHub para guardar configuración y estadísticas
GITHUB_TOKEN=tu_token_github_aqui

# API key para imgbb (subida de imágenes opcional)
IMGBB_API_KEY=tu_api_key_imgbb_aqui

# Token de Puter para modelo11 (Claude Sonnet 4.6)
# Obtén el token ejecutando: node scripts/get-puter-token.cjs
PUTER_AUTH_TOKEN=tu_token_de_puter_aqui

# Nota: Los modelos de Kilo no requieren API key - son gratuitos
# Puedes dejar vacío el campo key en la configuración