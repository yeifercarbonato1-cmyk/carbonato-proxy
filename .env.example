# Variables de entorno para Carbonato Proxy

# Token de GitHub para guardar configuración y estadísticas
GITHUB_TOKEN=tu_token_github_aqui

# API key para imgbb (subida de imágenes opcional)
IMGBB_API_KEY=tu_api_key_imgbb_aqui

# modelo11 usa OpenCode Zen (deepseek-v4-flash-free) - API key hardcodeada, no requiere env var
# La API key de Zen está configurada directamente en chat.js y admin-panel.js

# Nota: Los modelos de Kilo y Zen no requieren API key externa - son gratuitos
# Puedes dejar vacío el campo key en la configuración para modelos sin auth